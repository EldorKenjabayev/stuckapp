# ============================================
# Fenix Project - Environment Variables
# ============================================

# ─── Web Domain ─────────────────────────────
# Web sayt domeni - notificationlar uchun
# Development: http://localhost:8000
# Production: https://your-domain.com
WEB_DOMAIN=https://your-domain.com

# ─── Telegram Bot Token ───────────────────────
# Telegram bot tokenni shu yerga joylang
# @BotFather dan olgan tokeningizni kiritng
# Tokenni hech kim bilan bo'lishmang!
TELEGRAM_BOT_TOKEN=1234567890:ABCDEFghijklmnopqrstuvwxyz

# ─── Database (PostgreSQL) ─────────────────
# Production rejimda PostgreSQL ishlating
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# ─── Redis (Daphne) ──────────────────────
# WebSocket uchun Redis server
# REDIS_URL=redis://localhost:6379/0

# ─── Security ─────────────────────────────
# Django secret key - production rejimda o'zgartiring
# python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
# SECRET_KEY=djangoinsecure-...
